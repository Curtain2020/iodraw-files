        <mxCell id="YmROhvMCN7dqF26cxkyT-72" value="" style="endArrow=none;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=2;exitX=0.999;exitY=0.432;exitDx=0;exitDy=0;exitPerimeter=0;" edge="1" parent="1" source="YmROhvMCN7dqF26cxkyT-66" target="YmROhvMCN7dqF26cxkyT-67">
          <mxGeometry width="50" height="50" relative="1" as="geometry">

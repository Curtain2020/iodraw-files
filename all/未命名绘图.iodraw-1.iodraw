        <mxCell id="YmROhvMCN7dqF26cxkyT-66" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;基础元数据&lt;/b&gt;&lt;/font&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp; 名称：&lt;/b&gt;比值的定义&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp; 学段：&lt;/b&gt;小学六年级&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp; 描述：&lt;/b&gt;比表示两个数之间的倍数关系，把比&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;的前&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;项以后项，所得结果叫比值。比值是一&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;个数值，&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;表示前项是后项的几倍或几分之&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;几。&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="-10" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="YmROhvMCN7dqF26cxkyT-67" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;基础元数据&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/span&gt;&lt;div style=&quot;font-size: 14px;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp; 名称：&lt;/b&gt;比值的定义&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp; 学段：&lt;/b&gt;小学六年级&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;&amp;nbsp; 描述：&lt;/b&gt;比表示两个数之间的倍数关系，把比&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;的前&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;项以后项，所得结果叫比值。比值是一&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;个数值，&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;表示前项是后项的几倍或几分之&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;几。&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="-12" width="340" height="150" as="geometry" />
        </mxCell>
        <mxCell id="YmROhvMCN7dqF26cxkyT-69" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/span&gt;&lt;font size=&quot;1&quot; style=&quot;&quot; color=&quot;#009900&quot;&gt;&lt;b style=&quot;font-size: 16px;&quot;&gt;认知状态向量&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 13px; text-align: left;&quot;&gt;&lt;span style=&quot;background-color: initial; color: rgb(0, 153, 0);&quot;&gt;[ 记忆/理解(M): 0,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; color: rgb(0, 153, 0);&quot;&gt;应用/分析(U): 0,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; color: rgb(0, 153, 0);&quot;&gt;评价/创造&lt;/span&gt;&lt;span style=&quot;background-color: initial; color: rgb(0, 153, 0);&quot;&gt;(C): 0 ]&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
